# Environment configuration for Sanctii
# -------------------------------------
# This file is for local development only and should NOT be committed with
# real secrets. Replace values with placeholders or load from your shell
# environment. Use .env.local (gitignored) for sensitive values.

# Auth0 settings
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=

# Backend database
MONGO_URI=

# Google Maps for distance lookups (server-side)
GOOGLE_MAPS_API_KEY=

# Optional third-party keys
SMARTSPECTRA_API_KEY=

# API exposed to the frontend (will be baked into the bundle)
VITE_API_BASE=http://localhost:3001
VITE_GEMINI_API_KEY=
VITE_GROQ_API_KEY=

# Server-only secrets
GEMINI_API_KEY=
GROQ_API_KEY=

